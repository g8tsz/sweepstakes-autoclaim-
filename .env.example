# Persist Chrome across restarts (optional)
CHROME_USER_DATA_DIR=/data/chrome
CHROME_PROFILE_DIR=Default


# Google auth — required for Stake, Fortune Coins, and all universal (config-driven) casinos.
# Format: email:password . Then run !auth google once (or use persistent Chrome profile).
#GOOGLE_LOGIN=your@gmail.com:yourpassword
GOOGLE_LOGIN=

# Optional: path to universal casinos config (default: casinos_universal.json in project root).
#UNIVERSAL_CASINOS_CONFIG=casinos_universal.json

# Optional: path to per-user profiles (default: user_profiles.json). Contains sensitive data; restrict permissions.
#USER_PROFILES_PATH=user_profiles.json

# Optional: Discord user ID whose /profile credentials the automated loop uses for universal casinos.
#DEFAULT_PROFILE_USER_ID=

# Optional: Discord guild (server) ID to sync slash commands to that guild for faster updates.
#DISCORD_GUILD_ID=

# Optional: Fernet key to encrypt user_profiles.json (generate with cryptography.fernet.Fernet.generate_key()).
#PROFILE_ENCRYPTION_KEY=

# Optional: file path to log profile actions (user id + action only; no credentials).
#PROFILE_AUDIT_LOG=profile_audit.log

# Optional: max /profile set_google and set_casino calls per user per minute (default: 5).
#PROFILE_RATE_LIMIT_PER_MINUTE=5

# ---------- Website (run_web.py / uvicorn web.app:app) ----------
# Secret for signing session cookies. Set in production.
#WEB_SECRET=change-me-in-production
# SQLite path for web users, profiles, run history (default: web_data.db).
#WEB_DATABASE_PATH=web_data.db
# Set to 0 to disable background automation (site still works; no Chrome needed).
#WEB_WORKER_ENABLED=1
# Seconds between full casino runs per user when loop is on (default: 7200 = 2h).
#WEB_LOOP_INTERVAL_SEC=7200
# Set to 1 for HTTPS-only cookie (production).
#WEB_COOKIE_SECURE=0

STAKE=

